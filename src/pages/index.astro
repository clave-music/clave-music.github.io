---
import HomeLayout from '../layouts/HomeLayout.astro';
import MusicPreview from '../components/MusicPreview.astro';

const features = [
	{
		title: 'Readable by design',
		body: 'The syntax is intentionally compact so musicians can read and write scores without XML noise getting in the way.',
	},
	{
		title: 'Version-control friendly',
		body: 'Small text changes produce meaningful diffs, making review and collaboration much easier than binary or verbose markup formats.',
	},
	{
		title: 'Targets standard outputs',
		body: 'Clave compiles to MusicXML and MEI so downstream engraving, archival, and notation tools can keep doing the heavy lifting.',
	},
	{
		title: 'Built for tooling',
		body: 'The language and ecosystem are designed for editor support, validation, and future plugin-based extensions.',
	},
];

const links = [
	{
		label: 'Install CLI',
		href: 'https://www.npmjs.com/package/@clave/cli',
		meta: 'npm install -g @clave/cli',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/clave-music',
		meta: 'source, issues, releases',
	},
	{
		label: 'VS Code',
		href: 'https://github.com/clave-music/clave-vscode',
		meta: 'language support and preview',
	},
	{
		label: 'Web Editor',
		href: 'https://github.com/clave-music/clave-web',
		meta: 'browser-based editing surface',
	},
];

const reasons = [
	'You can edit music in the same workflow you already use for code review and release management.',
	'Plain text keeps the source of truth portable across editors, CI, and future automation.',
	'The language stays focused on musical content, while rendering and engraving remain separate concerns.',
];

const codeSample = String.raw`title: "Ode to Joy"
composer: "Beethoven"
time: 4/4
key: D major
tempo: 120

voice 1 {
  E4/4 E4 F4 G4 | G4 F4 E4 D4 |
  C4 C4 D4 E4   | E4/4. D4/8 D4/2 |
}`;
---

<HomeLayout
	title="Clave"
	description="Clave is a human-friendly DSL for writing music. Readable source, standard notation output, and a rendered preview powered by OSMD."
>
	<main class="relative isolate overflow-hidden">
		<div class="pointer-events-none absolute inset-0 -z-10">
			<div class="absolute left-[-10rem] top-[-6rem] h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"></div>
			<div class="absolute right-[-8rem] top-24 h-72 w-72 rounded-full bg-emerald-400/10 blur-3xl"></div>
			<div class="absolute inset-x-0 top-[34rem] h-px bg-gradient-to-r from-transparent via-slate-400/30 to-transparent"></div>
		</div>

		<section class="mx-auto max-w-7xl px-6 pb-16 pt-8 sm:px-8 lg:px-10 lg:pb-24 lg:pt-10">
			<header class="mb-16 flex items-center justify-between gap-4">
				<a href="/" class="inline-flex items-center gap-3 text-lg font-semibold tracking-wide text-white">
					<span class="grid h-10 w-10 place-items-center rounded-2xl border border-white/10 bg-white/5 text-sm shadow-lg shadow-cyan-950/30">
						C
					</span>
					<span>Clave</span>
				</a>
				<nav class="hidden items-center gap-6 text-sm text-slate-300 md:flex">
					<a class="transition hover:text-white" href="/docs/">Docs</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music">GitHub</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music/clave-vscode">VS Code</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music/clave-web">Web Editor</a>
				</nav>
			</header>

			<div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14">
				<div class="max-w-2xl">
					<p class="inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100">
						plain-text music notation
					</p>
					<h1 class="mt-6 text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">
						Write music like code.
						<span class="mt-2 block text-slate-300">Render it like notation.</span>
					</h1>
					<p class="mt-6 max-w-xl text-lg leading-8 text-slate-300 sm:text-xl">
						Clave is a human-friendly DSL for writing music that stays readable,
						writable, and version-control friendly. Source stays compact; rendering
						and engraving stay in the tools built for them.
					</p>

					<div class="mt-10 flex flex-wrap gap-4">
						<a
							href="/docs/"
							class="inline-flex items-center justify-center rounded-full bg-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition hover:-translate-y-0.5 hover:bg-cyan-300"
						>
							Read the docs
						</a>
						<a
							href="https://github.com/clave-music"
							class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
						>
							View GitHub
						</a>
					</div>

					<div class="mt-12 grid gap-4 sm:grid-cols-3">
						<div class="rounded-3xl border border-white/10 bg-white/5 p-4">
							<p class="text-sm font-semibold text-white">MusicXML</p>
							<p class="mt-2 text-sm leading-6 text-slate-300">
								Standard notation output for engraving software.
							</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/5 p-4">
							<p class="text-sm font-semibold text-white">MEI</p>
							<p class="mt-2 text-sm leading-6 text-slate-300">
								Archival and scholarly workflows when text matters.
							</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/5 p-4">
							<p class="text-sm font-semibold text-white">Preview</p>
							<p class="mt-2 text-sm leading-6 text-slate-300">
								Render the score directly in the browser with OSMD.
							</p>
						</div>
					</div>
				</div>

				<div class="grid gap-5">
					<div class="rounded-[2rem] border border-white/10 bg-slate-950/75 p-5 shadow-[0_30px_120px_-50px_rgba(15,23,42,1)] backdrop-blur">
						<div class="mb-4 flex items-center justify-between">
							<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
								DSL example
							</p>
							<span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs text-emerald-200">
								plain text
							</span>
						</div>
						<pre class="overflow-x-auto rounded-2xl border border-white/10 bg-slate-950 p-5 text-sm leading-7 text-slate-200 shadow-inner"><code>{codeSample}</code></pre>
					</div>

					<MusicPreview />
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10">
			<div class="max-w-3xl">
				<p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-200/70">
					Why plain-text music notation
				</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
					Notation should be easy to review, easy to revise, and hard to lose.
				</h2>
			</div>

			<div class="mt-10 grid gap-5 md:grid-cols-3">
				{reasons.map((reason) => (
					<div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-slate-200 shadow-lg shadow-slate-950/20">
						<p class="text-lg leading-8">{reason}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10">
			<div class="flex flex-wrap items-end justify-between gap-4">
				<div class="max-w-3xl">
					<p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-200/70">
						Features
					</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						Focus on the source, not the serialization format.
					</h2>
				</div>
				<a href="/docs/" class="text-sm font-semibold text-cyan-200 transition hover:text-cyan-100">
					Browse docs
				</a>
			</div>

			<div class="mt-10 grid gap-5 lg:grid-cols-2">
				{features.map((feature) => (
					<article class="rounded-[1.75rem] border border-white/10 bg-slate-950/70 p-6 shadow-lg shadow-slate-950/20">
						<h3 class="text-xl font-semibold text-white">{feature.title}</h3>
						<p class="mt-3 max-w-xl text-base leading-7 text-slate-300">{feature.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10">
			<div class="rounded-[2rem] border border-white/10 bg-white/5 p-6 shadow-[0_25px_100px_-60px_rgba(15,23,42,1)] sm:p-8">
				<div class="max-w-3xl">
					<p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-200/70">
						Install and tools
					</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						Drop Clave into your workflow.
					</h2>
				</div>

				<div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
					{links.map((link) => (
						<a
							href={link.href}
							class="group rounded-3xl border border-white/10 bg-slate-950/70 p-5 transition hover:-translate-y-0.5 hover:border-cyan-400/30 hover:bg-slate-900"
						>
							<p class="text-lg font-semibold text-white">{link.label}</p>
							<p class="mt-2 text-sm leading-6 text-slate-300">{link.meta}</p>
							<p class="mt-4 text-sm font-mono text-cyan-200/80 transition group-hover:text-cyan-100">
								open link
							</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-20 sm:px-8 lg:px-10">
			<div class="rounded-[2rem] border border-cyan-400/15 bg-gradient-to-r from-cyan-400/10 via-slate-950/80 to-emerald-400/10 p-8 shadow-[0_30px_120px_-60px_rgba(6,182,212,0.45)] sm:p-10">
				<div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.3em] text-cyan-200/70">
							Get started
						</p>
						<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
							Use the docs to learn the syntax, then build scores in plain text.
						</h2>
						<p class="mt-4 max-w-2xl text-base leading-8 text-slate-300">
							The homepage introduces the workflow. The docs will carry the language
							specification and reference material as they land.
						</p>
					</div>
					<div class="flex flex-wrap gap-4 lg:justify-end">
						<a
							href="/docs/"
							class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-cyan-50"
						>
							Open docs
						</a>
						<a
							href="https://github.com/clave-music"
							class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
						>
							Explore GitHub
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</HomeLayout>
