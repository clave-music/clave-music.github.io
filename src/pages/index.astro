---
import HomeLayout from '../layouts/HomeLayout.astro';
import MusicPreview from '../components/MusicPreview.astro';
import TerminalArt from '../components/TerminalArt.astro';
import BrandMark from '../components/BrandMark.astro';

const features = [
	{
		title: 'Readable by design',
		body: 'A compact syntax musicians can read and write directly — no XML noise, no binary blobs between you and the music.',
	},
	{
		title: 'Version-control friendly',
		body: 'Plain text means small, meaningful diffs. Review a change, blame a measure, branch an arrangement — like any other source file.',
	},
	{
		title: 'Standard outputs',
		body: 'Compiles to MusicXML and MEI, so MuseScore, Finale, Sibelius, Dorico and scholarly tools keep doing the engraving.',
	},
	{
		title: 'Multi-voice & multi-staff',
		body: 'Write independent voices and staves in the same score. Polyphony stays legible in the source, not buried in markup.',
	},
	{
		title: 'Extensible via plugins',
		body: 'Emitters are pluggable. MusicXML and MEI ship in core; ABC, LilyPond, MIDI and more can be added without forking the compiler.',
	},
	{
		title: 'Built for tooling',
		body: 'A formal grammar drives the language, so editor support, validation, and diagnostics come from one source of truth.',
	},
];

const links = [
	{
		label: 'Install CLI',
		href: 'https://www.npmjs.com/package/@clave/cli',
		meta: 'npm install -g @clave/cli',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/clave-music',
		meta: 'source, issues, releases',
	},
	{
		label: 'VS Code',
		href: 'https://github.com/clave-music/clave-vscode',
		meta: 'language support and preview',
	},
	{
		label: 'Web Editor',
		href: 'https://github.com/clave-music/clave-web',
		meta: 'browser-based editing surface',
	},
];

const codeSample = String.raw`title: "Ode to Joy"
composer: "Beethoven"
time: 4/4
key: D major
tempo: 120

voice 1 {
  E4/4 E4 F4 G4 | G4 F4 E4 D4 |
  C4 C4 D4 E4   | E4/4. D4/8 D4/2 |
}`;
---

<HomeLayout>
	<main class="relative isolate overflow-hidden">
		<div class="mx-auto max-w-7xl px-6 pb-24 pt-8 sm:px-8 lg:px-10">
			<header class="mb-10 flex items-center justify-between gap-4">
				<a href="/" class="inline-flex items-center"><BrandMark /></a>
				<nav class="hidden items-center gap-8 text-sm text-[var(--color-fg-2)] md:flex">
					<a class="transition hover:text-[var(--color-fg)]" href="#philosophy">Philosophy</a>
					<a class="transition hover:text-[var(--color-fg)]" href="#features">Features</a>
					<a class="transition hover:text-[var(--color-fg)]" href="https://github.com/clave-music">GitHub</a>
				</nav>
			</header>

			<!-- Hero -->
			<section class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
				<div class="max-w-2xl">
					<div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line-2)] px-4 py-1.5 text-xs font-medium uppercase tracking-[0.22em] text-[var(--color-amber)]">
						<span class="h-1.5 w-1.5 rounded-full bg-[var(--color-amber)] shadow-[0_0_10px_var(--color-amber)]"></span>
						plain-text music notation
					</div>
					<h1 class="mt-7 text-5xl font-bold leading-[1.05] tracking-tight text-[var(--color-fg)] sm:text-6xl lg:text-7xl">
						Write music like code.
						<span class="mt-2 block text-[var(--color-fg-2)]">Render it like notation.</span>
					</h1>
					<p class="mt-7 max-w-xl text-lg leading-8 text-[var(--color-fg-2)]">
						Clave is a human-friendly DSL for writing music. It describes the
						<span class="text-[var(--color-amber)]">musical content</span> — notes, rhythms,
						voices — and leaves engraving, spacing, and layout to the tools built for them.
					</p>

					<div class="mt-10 flex flex-wrap gap-4">
						<a href="#features" class="inline-flex items-center justify-center rounded-full bg-[var(--color-amber)] px-6 py-3 text-sm font-semibold text-[var(--color-ink)] transition hover:-translate-y-0.5 hover:bg-[var(--color-amber-bright)]">
							Explore the language
						</a>
						<a href="https://github.com/clave-music" class="inline-flex items-center justify-center rounded-full border border-[var(--color-line-2)] px-6 py-3 text-sm font-semibold text-[var(--color-fg)] transition hover:-translate-y-0.5 hover:border-[var(--color-amber)]/60">
							View on GitHub
						</a>
					</div>
				</div>

				<TerminalArt />
			</section>

			<!-- Philosophy -->
			<section id="philosophy" class="mt-32 max-w-4xl">
				<p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-amber)]">Philosophy</p>
				<h2 class="mt-5 text-3xl font-bold leading-tight tracking-tight text-[var(--color-fg)] sm:text-4xl">
					Clave describes music, not engraving — the rest is someone else's problem.
				</h2>
				<p class="mt-6 text-lg leading-8 text-[var(--color-fg-2)]">
					Traditional notation files are XML: verbose, hard to write by hand, painful to
					diff. Clave gives you a clean syntax a musician can read and write directly,
					while still targeting the formats every tool expects. Layout, spacing, and
					rendering are delegated downstream. Clave's only job is to let you write music
					quickly and correctly.
				</p>
			</section>

			<!-- DSL example + live preview -->
			<section class="mt-24 grid gap-6 lg:grid-cols-2">
				<div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-panel)] p-5">
					<div class="mb-4 flex items-center justify-between">
						<p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--color-fg-3)]">DSL example</p>
						<span class="rounded-full border border-[var(--color-line-2)] px-3 py-1 text-xs text-[var(--color-fg-2)]">plain text</span>
					</div>
					<pre class="overflow-x-auto rounded-xl border border-[var(--color-line)] bg-[var(--color-ink-2)] p-5 font-mono text-sm leading-7 text-[var(--color-fg)]"><code>{codeSample}</code></pre>
				</div>
				<MusicPreview />
			</section>

			<!-- Features -->
			<section id="features" class="mt-32">
				<p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-amber)]">Features</p>
				<h2 class="mt-5 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
					Focus on the source, not the serialization format.
				</h2>
				<div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{features.map((f) => (
						<article class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-panel)] p-6 transition hover:border-[var(--color-line-2)]">
							<h3 class="text-xl font-semibold text-[var(--color-fg)]">{f.title}</h3>
							<p class="mt-3 text-base leading-7 text-[var(--color-fg-2)]">{f.body}</p>
						</article>
					))}
				</div>
			</section>

			<!-- Install and tools -->
			<section id="install" class="mt-32">
				<p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-amber)]">Install and tools</p>
				<h2 class="mt-5 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
					Drop Clave into your workflow.
				</h2>
				<div class="mt-12 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
					{links.map((link) => (
						<a
							href={link.href}
							class="group rounded-2xl border border-[var(--color-line)] bg-[var(--color-panel)] p-5 transition hover:-translate-y-0.5 hover:border-[var(--color-amber)]/50"
						>
							<p class="text-lg font-semibold text-[var(--color-fg)]">{link.label}</p>
							<p class="mt-2 font-mono text-sm leading-6 text-[var(--color-fg-2)]">{link.meta}</p>
							<p class="mt-4 text-sm font-medium text-[var(--color-amber)] transition group-hover:translate-x-0.5">
								open link →
							</p>
						</a>
					))}
				</div>
			</section>

			<!-- Get started -->
			<section class="mt-32">
				<div class="rounded-[2rem] border border-[var(--color-amber)]/25 bg-[var(--color-panel)] p-10 sm:p-12">
					<div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
						<div>
							<p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-amber)]">Get started</p>
							<h2 class="mt-5 max-w-2xl text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
								Write scores in plain text. Let the tools engrave them.
							</h2>
							<p class="mt-4 max-w-2xl text-base leading-8 text-[var(--color-fg-2)]">
								Learn the syntax, install the CLI, and compile to MusicXML or MEI — then
								keep using the notation tools you already know.
							</p>
						</div>
						<div class="flex flex-wrap gap-4 lg:justify-end">
							<a href="https://www.npmjs.com/package/@clave/cli" class="inline-flex items-center justify-center rounded-full bg-[var(--color-amber)] px-6 py-3 text-sm font-semibold text-[var(--color-ink)] transition hover:-translate-y-0.5 hover:bg-[var(--color-amber-bright)]">
								Install the CLI
							</a>
							<a href="https://github.com/clave-music" class="inline-flex items-center justify-center rounded-full border border-[var(--color-line-2)] px-6 py-3 text-sm font-semibold text-[var(--color-fg)] transition hover:-translate-y-0.5 hover:border-[var(--color-amber)]/60">
								Explore GitHub
							</a>
						</div>
					</div>
				</div>
			</section>

			<footer class="mt-20 border-t border-[var(--color-line)] pt-8 text-sm text-[var(--color-fg-3)]">
				Clave — plain-text music notation.
			</footer>
		</div>
	</main>
</HomeLayout>
