---
import HomeLayout from '../layouts/HomeLayout.astro';
import MusicPreview from '../components/MusicPreview.astro';

const reasons = [
	{
		title: 'Readable source',
		body: 'Clave keeps the notation close to what a musician can scan, edit, and review without XML noise getting in the way.',
	},
	{
		title: 'Portable diffs',
		body: 'Plain text makes score changes easy to review in version control and easier to keep stable over time.',
	},
	{
		title: 'Standard outputs',
		body: 'MusicXML and MEI stay in the pipeline so engraving and archival tools can do the heavy lifting downstream.',
	},
];

const features = [
	{
		title: 'Notes, rhythms, and structure stay explicit',
		body: 'The language is compact, but the source still maps cleanly to what a score does rather than how a renderer lays it out.',
	},
	{
		title: 'Multi-voice writing stays practical',
		body: 'The syntax is designed for real scores, where more than one line of music needs to stay readable in a single file.',
	},
	{
		title: 'It compiles to tooling-friendly formats',
		body: 'MusicXML and MEI keep the output usable in notation software, scholarship workflows, and future integrations.',
	},
	{
		title: 'The ecosystem can grow around it',
		body: 'Editor support, compiler tooling, and later plugins all benefit from the language staying text-first and predictable.',
	},
];

const links = [
	{
		label: 'Install CLI',
		href: 'https://www.npmjs.com/package/@clave/cli',
		meta: 'npm install -g @clave/cli',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/clave-music',
		meta: 'source, issues, releases',
	},
	{
		label: 'VS Code',
		href: 'https://github.com/clave-music/clave-vscode',
		meta: 'language support and preview',
	},
	{
		label: 'Web Editor',
		href: 'https://github.com/clave-music/clave-web',
		meta: 'browser-based editing surface',
	},
];

const codeSample = String.raw`title: "Ode to Joy"
composer: "Beethoven"
time: 4/4
key: D major
tempo: 120

voice 1 {
  E4/4 E4 F4 G4 | G4 F4 E4 D4 |
  C4 C4 D4 E4   | E4/4. D4/8 D4/2 |
}`;
---

<HomeLayout
	title="Clave"
	description="Clave is a human-friendly DSL for writing music. Readable source, standard notation output, and a rendered preview powered by OSMD."
>
	<main class="relative isolate overflow-hidden">
		<div class="pointer-events-none absolute inset-0 -z-10 bg-[#050816]"></div>
		<div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[30rem] bg-[radial-gradient(circle_at_14%_15%,rgba(244,114,182,0.18),transparent_28%),radial-gradient(circle_at_84%_18%,rgba(34,211,238,0.16),transparent_26%),radial-gradient(circle_at_52%_0%,rgba(250,204,21,0.1),transparent_32%)]"></div>
		<div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-28 border-b border-white/5 bg-white/[0.01]"></div>

		<section class="mx-auto max-w-7xl px-6 pb-16 pt-8 sm:px-8 lg:px-10 lg:pb-20 lg:pt-8">
			<header class="flex items-center justify-between gap-4">
				<a href="/" class="inline-flex items-baseline gap-3 text-white">
					<span class="text-lg font-semibold uppercase tracking-[0.32em]">Clave</span>
					<span class="hidden text-xs uppercase tracking-[0.32em] text-slate-500 md:inline">
						plain-text music notation
					</span>
				</a>
				<nav class="hidden items-center gap-6 text-sm text-slate-300 md:flex">
					<a class="transition hover:text-white" href="/docs/">Docs</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music">GitHub</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music/clave-vscode">VS Code</a>
					<a class="transition hover:text-white" href="https://github.com/clave-music/clave-web">Web Editor</a>
				</nav>
			</header>

			<div class="mt-12 grid items-center gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:gap-14">
				<div class="order-2 max-w-2xl lg:order-1">
					<p class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-slate-200">
						<span class="h-2 w-2 rounded-full bg-amber-300 shadow-[0_0_12px_rgba(251,191,36,0.9)]"></span>
						plain-text music notation
					</p>
					<h1 class="mt-6 text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">
						Write music like code.
						<span class="mt-3 block max-w-xl text-slate-300">Render it like notation.</span>
					</h1>
					<p class="mt-6 max-w-xl text-lg leading-8 text-slate-300 sm:text-xl">
						Clave is a human-friendly DSL for writing music that stays readable,
						writable, and version-control friendly. The site should feel technical and
						editorial, not over-designed.
					</p>

					<div class="mt-10 flex flex-wrap gap-4">
						<a
							href="/docs/"
							class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-100"
						>
							Read the docs
						</a>
						<a
							href="https://github.com/clave-music"
							class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
						>
							View GitHub
						</a>
					</div>

					<div class="mt-12 grid gap-5 border-l border-white/8 pl-5 sm:grid-cols-3 sm:border-l-0 sm:pl-0">
						{reasons.map((item, index) => (
							<div class="space-y-2">
								<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">
									0{index + 1}
								</p>
								<p class="text-sm font-semibold text-white">{item.title}</p>
								<p class="text-sm leading-6 text-slate-300">{item.body}</p>
							</div>
						))}
					</div>
				</div>

				<figure class="order-1 lg:order-2">
					<div class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-slate-950/85 p-4 shadow-[0_40px_140px_-55px_rgba(0,0,0,0.9)]">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_14%_18%,rgba(244,114,182,0.16),transparent_24%),radial-gradient(circle_at_82%_16%,rgba(34,211,238,0.15),transparent_22%),radial-gradient(circle_at_54%_82%,rgba(250,204,21,0.08),transparent_28%)]"></div>
						<div class="relative overflow-hidden rounded-[2rem] border border-white/8 bg-[#04070f]">
							<img
								src="/brand/friendly-clef.png"
								alt="Friendly Clef mascot for Clave"
								class="block h-auto w-full object-cover"
							/>
						</div>
						<div class="relative mt-4 flex items-center justify-between gap-4 px-1">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">
									Friendly Clef
								</p>
								<p class="mt-1 text-sm text-slate-300">
									A large hero mark with a clear music-language feel.
								</p>
							</div>
							<a
								href="/docs/"
								class="hidden rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-slate-200 transition hover:bg-white/10 sm:inline-flex"
							>
								Docs
							</a>
						</div>
					</div>
				</figure>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-12 sm:px-8 lg:px-10">
			<div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
				<div class="max-w-xl">
					<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
						Why plain-text music notation
					</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						Notation should be easy to review, easy to revise, and hard to lose.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-300">
						The language should describe the music, not the renderer. That keeps the
						source readable, the workflow portable, and the output compatible with the
						tools that already know how to engrave and archive scores.
					</p>
				</div>

				<div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 sm:p-8">
					<div class="space-y-6">
						{features.map((feature, index) => (
							<div class:list={[
								'grid gap-4 border-t border-white/8 pt-6 first:border-t-0 first:pt-0 sm:grid-cols-[5rem_1fr]',
							]}>
								<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
									0{index + 1}
								</p>
								<div>
									<h3 class="text-lg font-semibold text-white">{feature.title}</h3>
									<p class="mt-2 max-w-2xl text-sm leading-7 text-slate-300">
										{feature.body}
									</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-12 sm:px-8 lg:px-10">
			<div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
				<div class="max-w-xl">
					<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
						Syntax snapshot
					</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						See the source and the rendered output side by side.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-300">
						One panel shows the DSL the user writes. The other panel shows the score as
						it will appear in the browser. That makes the homepage feel like the product,
						not just a brochure.
					</p>
					<div class="mt-8 rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">
							One rule
						</p>
						<p class="mt-3 text-sm leading-7 text-slate-300">
							A number on a pitch letter is the octave. Duration always follows a slash.
							The syntax stays unambiguous because the source stays compact.
						</p>
					</div>
				</div>

				<div class="grid gap-5">
					<div class="rounded-[2rem] border border-white/10 bg-slate-950/85 p-5 shadow-[0_30px_120px_-60px_rgba(0,0,0,0.9)]">
						<div class="mb-4 flex items-center justify-between gap-4">
							<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
								DSL example
							</p>
							<span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-slate-200">
								plain text
							</span>
						</div>
						<pre class="overflow-x-auto rounded-2xl border border-white/10 bg-[#050816] p-5 text-sm leading-7 text-slate-200 shadow-inner"><code>{codeSample}</code></pre>
					</div>

					<MusicPreview />
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-12 sm:px-8 lg:px-10">
			<div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr]">
				<div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 sm:p-8">
					<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
						Install and tools
					</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						Drop Clave into your workflow.
					</h2>
					<p class="mt-5 max-w-2xl text-base leading-8 text-slate-300">
						Start with the CLI, then move into editor support or the web editor if that
						better matches how you work. The page should point to the next action without
						scattering attention.
					</p>

					<div class="mt-8 grid gap-4 sm:grid-cols-2">
						{links.map((link) => (
							<a
								href={link.href}
								class="group rounded-3xl border border-white/10 bg-[#060816] p-5 transition hover:-translate-y-0.5 hover:bg-white/[0.06]"
							>
								<p class="text-lg font-semibold text-white">{link.label}</p>
								<p class="mt-2 text-sm leading-6 text-slate-300">{link.meta}</p>
								<p class="mt-4 text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 transition group-hover:text-slate-200">
									open link
								</p>
							</a>
						))}
					</div>
				</div>

				<div class="flex flex-col justify-between gap-6 rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 sm:p-8">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
							What it gives you
						</p>
						<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
							A text-first source of truth for music.
						</h2>
					</div>

					<div class="space-y-5">
						<div class="rounded-[1.5rem] border border-white/8 bg-[#050816] p-5">
							<p class="text-sm font-semibold text-white">Readable</p>
							<p class="mt-2 text-sm leading-7 text-slate-300">
								Score sources are meant to be scanned and edited by humans first.
							</p>
						</div>
						<div class="rounded-[1.5rem] border border-white/8 bg-[#050816] p-5">
							<p class="text-sm font-semibold text-white">Versionable</p>
							<p class="mt-2 text-sm leading-7 text-slate-300">
								Small changes stay obvious in diffs and easy to discuss in review.
							</p>
						</div>
						<div class="rounded-[1.5rem] border border-white/8 bg-[#050816] p-5">
							<p class="text-sm font-semibold text-white">Composable</p>
							<p class="mt-2 text-sm leading-7 text-slate-300">
								The tooling can grow around the language without bloating the source.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-16 sm:px-8 lg:px-10 pb-20">
			<div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 sm:p-8 lg:p-10">
				<div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<div class="max-w-2xl">
						<p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
							Get started
						</p>
						<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
							Use the docs to learn the syntax, then build scores in plain text.
						</h2>
						<p class="mt-5 text-base leading-8 text-slate-300">
							The homepage introduces the workflow. The docs carry the language
							specification and reference material as they land.
						</p>
					</div>

					<div class="flex flex-wrap gap-4 lg:justify-end">
						<a
							href="/docs/"
							class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-100"
						>
							Open docs
						</a>
						<a
							href="https://github.com/clave-music"
							class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
						>
							Explore GitHub
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</HomeLayout>
