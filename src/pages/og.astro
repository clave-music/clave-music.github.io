---
import { readFileSync } from 'node:fs';
import '../styles/global.css';

const codeSample = readFileSync(
	`${process.cwd()}/public/scores/odetojoy.clave`,
	'utf-8',
)
	.trim()
	.split('\n')
	.filter((line) => !/^(title|composer|time|key|tempo):/.test(line))
	.join('\n')
	.trim();

const escapeHtml = (s: string) =>
	s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const highlightClave = (source: string) =>
	source
		.split('\n')
		.map((line) =>
			line.replace(
				/\b(voice)\b|([{}|\]])|\b([A-G](?:#|b)?\d)(\/\d+\.?)?/g,
				(match, keyword, punct, note, duration) => {
					if (keyword) return `<span style="color: var(--color-amber);">${keyword}</span>`;
					if (punct) return `<span style="color: var(--color-fg-3);">${escapeHtml(punct)}</span>`;
					const durationHtml = duration
						? `<span style="color: #c4b5fd;">${duration}</span>`
						: '';
					return `<span style="color: #7dd3fc;">${note}</span>${durationHtml}`;
				},
			),
		)
		.join('\n');

const highlightedCode = highlightClave(codeSample);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<style>
			html,
			body {
				margin: 0;
				padding: 0;
				background: #000;
			}

			.og-canvas {
				position: relative;
				overflow: hidden;
				width: 1200px;
				height: 630px;
				font-family: var(--font-sans);
				color: var(--color-fg);
				background:
					linear-gradient(135deg, rgb(255 255 255 / 0.035) 0 1px, transparent 1px 96px),
					linear-gradient(115deg, transparent 0 58%, rgb(125 211 252 / 0.055) 58% 68%, transparent 68%),
					linear-gradient(155deg, transparent 0 64%, rgb(245 182 46 / 0.09) 64% 76%, transparent 76%),
					linear-gradient(90deg, rgb(10 10 11 / 0.98) 0%, rgb(10 10 11 / 0.96) 48%, rgb(17 17 19 / 0.98) 100%),
					var(--color-ink);
			}

			.og-canvas::before {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, rgb(255 255 255 / 0.035), transparent 36%, rgb(245 182 46 / 0.035));
				opacity: 0.84;
			}

			.og-canvas::after {
				content: "";
				position: absolute;
				inset: 22px;
				border: 1px solid rgb(255 255 255 / 0.055);
				pointer-events: none;
			}

			.scene {
				position: relative;
				z-index: 1;
				display: grid;
				grid-template-columns: 444px 1fr;
				height: 100%;
				gap: 56px;
				align-items: center;
				padding: 0 64px;
			}

			.brand {
				display: flex;
				flex-direction: column;
				gap: 28px;
				padding-top: 4px;
			}

			.wordmark {
				width: 232px;
				height: auto;
				margin-left: -7px;
				filter: drop-shadow(0 18px 34px rgb(245 182 46 / 0.2));
			}

			.eyebrow {
				display: inline-flex;
				width: fit-content;
				align-items: center;
				gap: 10px;
				border: 1px solid rgb(245 182 46 / 0.28);
				border-radius: 8px;
				background: rgb(245 182 46 / 0.09);
				padding: 8px 13px;
				font-family: var(--font-mono);
				font-size: 12px;
				font-weight: 500;
				color: var(--color-amber-bright);
			}

			.eyebrow::before {
				content: "";
				width: 7px;
				height: 7px;
				border-radius: 999px;
				background: var(--color-amber);
				box-shadow: 0 0 18px rgb(245 182 46 / 0.72);
			}

			.headline {
				margin: 0;
				max-width: 480px;
				font-size: 50px;
				font-weight: 700;
				line-height: 1.03;
				color: var(--color-fg);
			}

			.headline span {
				display: block;
				color: var(--color-fg-2);
			}

			.subcopy {
				margin: -8px 0 0;
				max-width: 410px;
				font-size: 18px;
				font-weight: 500;
				line-height: 1.45;
				color: rgb(244 244 243 / 0.7);
			}

			.product {
				position: relative;
				height: 438px;
			}

			.product::before {
				content: "";
				position: absolute;
				inset: 56px -26px 22px 54px;
				border: 1px solid rgb(255 255 255 / 0.06);
				background:
					linear-gradient(115deg, rgb(255 255 255 / 0.08), transparent 34%),
					rgb(22 22 25 / 0.38);
				transform: skewX(-7deg);
				box-shadow: 0 36px 110px -62px rgb(0 0 0 / 1);
			}

			.product-card {
				position: absolute;
				border: 1px solid rgb(255 255 255 / 0.14);
				border-radius: 8px;
				background: rgb(22 22 25 / 0.88);
				box-shadow:
					0 42px 92px -58px rgb(0 0 0 / 1),
					inset 0 1px 0 rgb(255 255 255 / 0.08);
				backdrop-filter: blur(16px);
			}

			.source-card {
				top: 2px;
				right: 0;
				width: 552px;
				padding: 18px;
			}

			.score-card {
				right: 0;
				bottom: 0;
				width: 552px;
				padding: 18px;
			}

			.card-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 12px;
				font-family: var(--font-mono);
				font-size: 11px;
				font-weight: 500;
				text-transform: uppercase;
				color: var(--color-fg-3);
			}

			.window-controls {
				display: flex;
				gap: 7px;
			}

			.window-controls span {
				width: 8px;
				height: 8px;
				border-radius: 999px;
				background: rgb(255 255 255 / 0.18);
			}

			.window-controls span:first-child {
				background: var(--color-amber);
			}

			.code-shell {
				overflow: hidden;
				border: 1px solid rgb(255 255 255 / 0.08);
				border-radius: 8px;
				background:
					linear-gradient(180deg, rgb(255 255 255 / 0.025), transparent 46%),
					var(--color-ink-2);
				padding: 20px 22px;
			}

			pre {
				margin: 0;
				font-family: var(--font-mono);
				font-size: 17px;
				line-height: 1.72;
				color: var(--color-fg);
			}

			.score-shell {
				display: flex;
				align-items: center;
				justify-content: center;
				height: 116px;
				overflow: hidden;
				border: 1px solid rgb(10 10 11 / 0.12);
				border-radius: 8px;
				background:
					linear-gradient(180deg, #ffffff, #f1f1ef);
				padding: 10px 14px;
				box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.72);
			}

			.badge-row {
				display: flex;
				gap: 10px;
				margin-top: 6px;
			}

			.badge {
				border: 1px solid rgb(255 255 255 / 0.09);
				border-radius: 8px;
				background: rgb(255 255 255 / 0.045);
				padding: 7px 11px;
				font-family: var(--font-mono);
				font-size: 12px;
				color: rgb(244 244 243 / 0.68);
			}

			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}
		</style>
	</head>
	<body>
		<div id="og-canvas" class="og-canvas">
			<div class="scene">
				<section class="brand" aria-label="Clave product summary">
					<img class="wordmark" src="/brand/clave-wordmark.svg" alt="Clave" />
					<div class="eyebrow">Plain-text music notation DSL</div>
					<h1 class="headline">
						Write music like code.
						<span>Engrave it with tools you trust.</span>
					</h1>
					<p class="subcopy">
						Write the music. Let engraving tools shape the page.
					</p>
					<div class="badge-row" aria-hidden="true">
						<span class="badge">.clave</span>
						<span class="badge">MusicXML</span>
						<span class="badge">MEI</span>
						<span class="badge">MIDI</span>
					</div>
				</section>

				<div class="product" aria-label="Clave source and rendered notation preview">
					<div class="product-card source-card">
						<div class="card-top">
							<span>Clave source</span>
							<div class="window-controls" aria-hidden="true">
								<span></span>
								<span></span>
								<span></span>
							</div>
						</div>
						<div class="code-shell">
							<pre><code set:html={highlightedCode} /></pre>
						</div>
					</div>
					<div class="product-card score-card">
						<div class="card-top">
							<span>Rendered score</span>
							<span>SVG notation</span>
						</div>
						<div class="score-shell" data-osmd-preview>
							<span class="sr-only">Loading score preview...</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<script type="module">
			import { OpenSheetMusicDisplay } from 'opensheetmusicdisplay';

			const mount = document.querySelector('[data-osmd-preview]');

			if (mount) {
				const musicXml = await fetch('/scores/odetojoy.musicxml').then((res) => res.text());

				mount.replaceChildren();
				const osmd = new OpenSheetMusicDisplay(mount, {
					autoResize: true,
					backend: 'svg',
					drawTitle: false,
					drawComposer: false,
				});

				await osmd.load(musicXml);
				osmd.Zoom = 0.7;
				osmd.render();
			}
		</script>
	</body>
</html>
