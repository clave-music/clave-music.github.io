---
const mascot = '/brand/mascot.png';
---

<div class="relative mx-auto flex aspect-square w-full max-w-md items-center justify-center lg:max-w-none">
	<!-- single amber glow behind mascot -->
	<div class="pointer-events-none absolute left-1/2 top-1/2 h-80 w-80 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-amber)]/20 blur-3xl"></div>

	<img
		src={mascot}
		alt="Clave mascot"
		class="relative max-h-[100%] max-w-[100%] object-contain drop-shadow-[0_30px_50px_rgba(0,0,0,0.7)]"
	/>
</div>
