---
interface Props {
	variant?: 'header' | 'hero';
}

const { variant = 'header' } = Astro.props as Props;
const isHero = variant === 'hero';
---

<div class:list={[
	'flex items-center gap-3',
	isHero ? 'gap-4' : 'gap-3',
]}>
	<div class:list={[
		'grid shrink-0 place-items-center rounded-[1.35rem] bg-gradient-to-br from-fuchsia-500/40 via-cyan-400/35 to-emerald-400/40 p-[1px] shadow-[0_0_0_1px_rgba(255,255,255,0.05),0_16px_40px_-18px_rgba(45,212,191,0.6)]',
		isHero ? 'h-[7.25rem] w-[7.25rem]' : 'h-11 w-11',
	]}>
		<div class:list={[
			'overflow-hidden rounded-[calc(1.35rem-1px)] bg-slate-950',
			isHero ? 'h-[calc(7.25rem-2px)] w-[calc(7.25rem-2px)]' : 'h-[calc(2.75rem-2px)] w-[calc(2.75rem-2px)]',
		]}>
			<img
				src="/brand/friendly-clef.png"
				alt=""
				aria-hidden="true"
				class:list={[
					'h-full w-full object-cover',
					isHero ? 'scale-[1.02]' : 'scale-110',
				]}
			/>
		</div>
	</div>

	<div class:list={['min-w-0', isHero ? 'space-y-1' : 'space-y-0.5']}>
		<p class:list={[
			'font-semibold tracking-[0.26em] text-white uppercase',
			isHero ? 'text-sm' : 'text-[0.72rem]',
		]}>
			Clave
		</p>
		{isHero ? (
			<p class="text-sm font-medium tracking-[0.2em] text-slate-400 uppercase">
				Friendly Clef
			</p>
		) : (
			<p class="text-xs text-slate-400">plain-text music notation</p>
		)}
	</div>
</div>
